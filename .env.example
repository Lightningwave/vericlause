# VeriClause – copy to .env.local and fill in your keys

# LlamaCloud / LlamaParse – PDF parsing (replaces pdf-parse; supports complex/scanned docs)
LLAMA_CLOUD_API_KEY=

# Groq (free) – LLM for extraction and RAG verdicts
GROQ_API_KEY=

# Google Gemini (free) – embeddings for vector search
GEMINI_API_KEY=

# Pinecone (free tier) – vector database for law chunks
PINECONE_API_KEY=
PINECONE_INDEX=vericlause-laws

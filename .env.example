# VeriClause – copy to .env and fill in your keys

# Supabase (free tier) – authentication
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# LlamaCloud / LlamaParse – PDF parsing (replaces pdf-parse; supports complex/scanned docs)
LLAMA_CLOUD_API_KEY=

# OpenAI – primary LLM (gpt-4o-mini) + embeddings (text-embedding-3-small)
OPENAI_API_KEY=

# Groq (free) – fallback LLM for RAG verdicts when OpenAI fails
GROQ_API_KEY=

# Pinecone (free tier) – vector database for law chunks
PINECONE_API_KEY=
PINECONE_INDEX=vericlause-laws
